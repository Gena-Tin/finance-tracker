{
  "openapi": "3.0.0",
  "info": {
    "title": "Finance Tracker API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "/index.php": {
      "get": {
        "tags": ["Categories"],
        "summary": "Получить список категорий",
        "responses": {
          "200": {
            "description": "Успешный список из БД"
          }
        }
      }
    },
    "/transactions.php": {
      "get": {
        "tags": ["Transactions"],
        "summary": "Получить список всех операций",
        "responses": {
          "200": { "description": "Массив транзакций" }
        }
      }
    }
  }
}
